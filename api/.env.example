DATABASE_URL=mysql+pymysql://signdex:signdex@127.0.0.1:3307/signdex
CORS_ORIGINS=*

# Supabase (pour héberger les images des signatures + PNG des formes template v4 sous template-assets/v4/)
# Le bucket doit autoriser la lecture publique pour ce préfixe si tu veux que Gmail charge les coins colorés.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_API_KEY=
SUPABASE_STORAGE_BUCKET=SignDex

# Seed : si la table clients est vide, insère les clients initiaux (HelloPropre, etc.). Mettre 0 pour désactiver.
SIGNDEX_SEED_IF_EMPTY=1

